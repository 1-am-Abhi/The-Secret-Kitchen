# ==========================================================================
# The Secret Kitchen — API environment
# Copy to `.env` and fill in. Every variable is parsed and validated by
# src/config/env.ts at boot; a missing or malformed required value exits the
# process immediately rather than failing later at request time.
# ==========================================================================

# --- Runtime --------------------------------------------------------------
# development | test | production
NODE_ENV=development
# Port the HTTP server binds to. Render/Railway inject their own — read it, do
# not hardcode.
PORT=4000

# --- Database (required) --------------------------------------------------
# PostgreSQL connection string used by Prisma.
# Local:  postgresql://postgres:postgres@localhost:5432/secret_kitchen?schema=public
# Hosted: append ?sslmode=require and, on serverless Postgres, &connection_limit=1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/secret_kitchen?schema=public

# --- Auth (required) ------------------------------------------------------
# Signing key for admin JWTs. Minimum 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET=9fc9fcbe4487d79e1edc76ddf447a320bb30951b2b3393ba82d7144f4ab0bfc0
# Token lifetime. Accepts any `ms`-style span: 15m, 12h, 7d.
JWT_EXPIRES_IN=7d

# --- CORS -----------------------------------------------------------------
# Comma-separated allow-list of browser origins. Use "*" in development only.
#
# Each entry is an exact origin (scheme + host + optional port). One `*.`
# wildcard is allowed in the host position, matching a single subdomain label —
# that is how Vercel preview deployments are permitted, since their hostname
# changes on every push and cannot be listed ahead of time.
#
# An origin that is not listed is answered without the allow-origin header, so
# the browser blocks it. Note this must be the ORIGIN only: no trailing slash
# and no path. "https://example.com/" and "https://example.com/app" both fail
# to match, because the browser only ever sends "https://example.com".
CORS_ORIGIN=http://localhost:3000,https://thesecretkitchen.in,https://*.vercel.app

# --- Cloudinary (optional) ------------------------------------------------
# Leave blank to run without media uploads; POST /api/gallery/upload then
# returns 503 and every other route keeps working.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Root folder new assets are uploaded into.
CLOUDINARY_FOLDER=the-secret-kitchen

# --- Business identity ----------------------------------------------------
# Destination for every WhatsApp order handoff link. Digits only; a bare
# 10-digit Indian number is prefixed with 91 when the wa.me URL is built.
BUSINESS_WHATSAPP=919876543210
BUSINESS_NAME=The Secret Kitchen

# --- Seed admin -----------------------------------------------------------
# `npm run seed` upserts this admin and RESETS the password on every run.
# Set a real password via the environment in production — never commit one.
ADMIN_EMAIL=admin@thesecretkitchen.in
ADMIN_PASSWORD=ChangeMe@12345
ADMIN_NAME=Kitchen Admin

# --- Seed behaviour -------------------------------------------------------
# Seeds demo orders, customers and subscriptions. MUST stay false anywhere
# real: it would put fabricated revenue and fake customer names on the admin
# dashboard. The catalogue (menu, categories, offers, plans) always seeds.
SEED_DEMO_DATA=false

# --- Rate limiting --------------------------------------------------------
# Baseline window/limit for the whole /api surface. Individual public write
# routes apply their own, tighter budgets on top of this.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- Misc -----------------------------------------------------------------
# Maximum accepted JSON/urlencoded body size.
BODY_LIMIT=256kb
# Set to false to silence HTTP access logs.
LOG_REQUESTS=true
