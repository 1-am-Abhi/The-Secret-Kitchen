# ---------------------------------------------------------------------------
# The Secret Kitchen — frontend environment
# Copy to `.env.local` for development. Set the same keys in the Vercel
# dashboard for production. Everything prefixed NEXT_PUBLIC_ ships to the
# browser — never put secrets behind that prefix.
# ---------------------------------------------------------------------------

# Canonical site origin. Drives canonical URLs, sitemap and Open Graph tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API base URL (the Express service in ../server).
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Business contact channels surfaced across the site.
NEXT_PUBLIC_PHONE=+91 98765 43210
NEXT_PUBLIC_WHATSAPP=+91 98765 43210
NEXT_PUBLIC_EMAIL=hello@thesecretkitchen.in
